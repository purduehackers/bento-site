---
import Layout from "../layouts/Layout.astro";
import "../styles/main.css";
import "../styles/bento.css";
import Bento from "../components/bento.astro";
import { Dithering } from "@paper-design/shaders-react";
import Loader from "../components/loader.astro";
import { Image } from "astro:assets";

import blob1 from "../assets/blobs/blob1.webp";
import blob2 from "../assets/blobs/blob2.webp";
import blob3 from "../assets/blobs/blob3.webp";
import blob4 from "../assets/blobs/blob4.webp";
import blob5 from "../assets/blobs/blob5.webp";
import logo_stick from "../assets/blobs/logo.webp";
import topic_robin from "../assets/topics/robin.webp";
import topic_cube from "../assets/topics/cube.webp";
import topic_ferris from "../assets/topics/ferris.webp";
import topic_laser from "../assets/topics/lasertag.png";
---

<Layout>
  <Loader>
    <p slot="hi" class="load">loading...</p>
  </Loader>
  <a
    target="_blank"
    rel="noopener noreferrer"
    href="https://luma.com/qd2ja4q8"
    title="rsvp for bento!"
    class="rsvp noselect">rsvp</a
  >
  <Image width={300} alt={"blob sticker"} class="blob1 draggable sticker" src={blob1} />
  <Image width={300} alt={"blob sticker"} class="blob2 draggable sticker" src={blob2} />
  <Image width={300} alt={"blob sticker"} class="blob3 draggable sticker" src={blob3} />
  <Image width={300} alt={"blob sticker"} class="blob4 draggable sticker" src={blob4} />
  <Image width={300} alt={"blob sticker"} class="blob5 draggable sticker" src={blob5} />
  <Image
    width={300}
    alt={"logo sticker"}
    class="sticker logo"
    id="logo-sticker"
    src={logo_stick}
    {...{ "can-play": true } as any}
  />
  <Image width={300} alt={"robin sticker"} class="robin draggable topic" src={topic_robin} />
  <Image width={300} alt={"rubiks cube sticker"} class="cube draggable topic" src={topic_cube} />
  <Image
    width={300}
    alt={""}
    class="ferris draggable topic"
    src={topic_ferris}
  />
  <Image width ={300} alt={"laser tag sticker"} class= "laser draggable topic" src={topic_laser}/>

  <Bento>
    <div class="top-right noselect" slot="top-right">
      <p title="seen the show? now hear the tell">
        seen the <a
          target="_blank"
          rel="noopener noreferrer"
          title="link to more information about spill (the show)"
          href="https://spill.purduehackers.com">show?</a
        >
      </p>
      <p>now hear the tell.</p>
      <img style="pointer-events: none" src="/bento.svg" />
      <h1 title="heading: bento">bento</h1>
    </div>
    <p class="noselect" slot="l-vertical">
      Do you have a topic or project you just can't shut up about? Want to tell
      even more people about how amazing it is?
      <br />
      <br />
      Yes, yes you do.
      <br />
      <br />
      We're hosting BENTO, a WWDC-style event where YOU break the mold on sharing
      cool and interesting topics with Purdue students.
      <br />
      <br />
      You only need a title and a topic to sign-up. That's it!
    </p>
    <div class="button-row" slot="l-vertical">
      <a
        target="_blank"
        rel="noopener noreferrer"
        href="https://purduehackers.notion.site/317181f3b6ed803eba22d22ac4cb7029?pvs=105"
        class="speaker">be a speaker</a
      >
      <a
        target="_blank"
        rel="noopener noreferrer"
        href="https://luma.com/qd2ja4q8"
        class="rsvp rsvp-mobile noselect">rsvp</a
      >
    </div>
    <p class="bottom-left noselect" slot="bottom-left">
      <strong>topics include:</strong>
    </p>
    <p slot="bottom-left">
      rust crates, rubik's cubes, birds, ios tweaks, vr laser tag, and more!
    </p>
    <p class="noselect top-left" slot="top-left">7-10 PM April 11 KRAN 140</p>
  </Bento>

  <div class="dither-bg">
    <Dithering
      client:load
      width={`100vw`}
      height={`100vh`}
      colorBack="#FFFAE5"
      colorFront="#1500ff"
      shape="warp"
      type="4x4"
      size={2.8}
      speed={0.15}
      offsetX={-1}
      offsetY={-1}
    />
  </div>
  <!-- playhtml scripting -->
  <script>
    import { playhtml } from "playhtml";
    const logo = document.getElementById("logo-sticker") as any;

    logo.defaultData = { x: 0, y: 0 };

    logo.updateElement = ({ element, data }: any) => {
      element.style.transform = `translate(${data.x}px, ${data.y}px)`;
    };

    logo.onMount = ({ getData, setData }: any) => {
      logo.addEventListener("mousedown", () => {
        const onMove = (e: MouseEvent) => {
          const data = getData();
          const w = logo.offsetWidth;
          const h = logo.offsetHeight;
          const vw = window.innerWidth;
          const vh = window.innerHeight;

          const baseLeft = logo.offsetLeft;
          const baseTop = logo.offsetTop;

          const rawX = data.x + e.movementX;
          const rawY = data.y + e.movementY;

          setData({
            x: Math.min(Math.max(rawX, -baseLeft), vw - baseLeft - w),
            y: Math.min(Math.max(rawY, -baseTop), vh - baseTop - h),
          });
        };

        document.addEventListener("mousemove", onMove);
        document.addEventListener(
          "mouseup",
          () => {
            document.removeEventListener("mousemove", onMove);
          },
          { once: true },
        );
      });
    };
    playhtml.init({
      cursors: {
        enabled: true,
        onCustomCursorRender: () => {
          const el = document.createElement("div");
          const img = document.createElement("img");
          img.setAttribute("src", "/./cursors/user-pointer.png");
          el.appendChild(img);
          return el;
        },
      },
    });
  </script>
  <!-- sticker scripting -->
  <script>
    const dragElements = document.querySelectorAll<HTMLElement>(".draggable");

    function onMouseDrag(event: MouseEvent, element: HTMLElement) {
      let leftValue = parseInt(window.getComputedStyle(element).left);
      let topValue = parseInt(window.getComputedStyle(element).top);

      const rect = element.getBoundingClientRect();
      const vw = window.innerWidth;
      const vh = window.innerHeight;

      // Compute proposed new position
      let newLeft = leftValue + event.movementX;
      let newTop = topValue + event.movementY;

      const minLeft = leftValue - rect.left; // left edge at 0
      const maxLeft = leftValue + (vw - rect.right); // right edge at vw
      const minTop = topValue - rect.top; // top edge at 0
      const maxTop = topValue + (vh - rect.bottom); // bottom edge at vh

      newLeft = Math.min(Math.max(newLeft, minLeft), maxLeft);
      newTop = Math.min(Math.max(newTop, minTop), maxTop);

      element.style.left = `${newLeft}px`;
      element.style.top = `${newTop}px`;
    }

    dragElements.forEach((element) => {
      element.addEventListener("mousedown", (e: MouseEvent) => {
        const onMove = (event: MouseEvent) => onMouseDrag(event, element);

        document.addEventListener("mousemove", onMove);
        document.addEventListener(
          "mouseup",
          () => {
            document.removeEventListener("mousemove", onMove);
          },
          { once: true },
        );
      });
    });
  </script>
</Layout>
