<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bento Layout</title>
  <style>
    /* body {
      margin: 0;
      padding: 2rem;
      box-sizing: border-box;
    } */

    .bento-wrapper {
      width: 100%;
      max-width: 1050px;
      margin: 0 auto;
      padding: 2rem;
      box-sizing: border-box;
    }

    /*
      Outer container: position relative so both layers
      can be stacked on top of each other.
      aspect-ratio locks proportions to match the SVG viewBox (780:630).
    */
    .bento {
      position: relative;
      width: 100%;
      aspect-ratio: 780 / 630;
    }

    /*
      SVG sits on top as a pure border layer.
      pointer-events: none so it doesn't block clicks on content below.
    */
    .bento-borders {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 1;
    }

    /* Content layer sits underneath the SVG */
    .bento-content {
      position: absolute;
      inset: 0;
    }

    .cell {
      position: absolute;
      box-sizing: border-box;
      padding: 16px;
      background-color: #FFFAE5;
    }

    /*
      Percentages derived from SVG coordinates divided by viewBox size:
        top vertical divider:    212 / 780 = 27.2%
        bottom vertical divider: 280 / 780 = 35.9%
        L cutout right edge:     500 / 780 = 64.1%
        horizontal divider:      227 / 630 = 36%
        L cutout bottom edge:    403 / 630 = 64%
    */

    .cell-top-left {
      left:   0;
      top:    0;
      width:  27.2%;
      height: 36%;
    }

    .cell-top-right {
      left:   27.2%;
      top:    0;
      width:  72.8%;
      height: 36%;
    }

    .cell-bottom-left {
      left:   0;
      top:    36%;
      width:  35.9%;
      height: 64%;
    }

    /* right vertical strip of the L */
    .cell-bottom-right-a {
      left:   64.1%;
      top:    36%;
      width:  35.9%;
      height: 64%;
    }

    /* bottom horizontal strip of the L, below the cutout */
    .cell-bottom-right-b {
      left:   35.9%;   /* 280 / 780 */
      top:    64%;     /* 403 / 630 */
      width:  28.2%;   /* 220 / 780 */
      height: 36%;     /* 227 / 630 */
    }
  </style>
</head>
<body>

  <div class="bento-wrapper">
    <div class="bento">

      <!-- CONTENT LAYER -->
      <div class="bento-content">

        <div class="cell cell-top-left">
          <slot name="top-left"></slot>
        </div>

        <div class="cell cell-top-right">
          <slot name="top-right"></slot>
        </div>

        <div class="cell cell-bottom-left">
          <slot name="bottom-left"></slot>  
        </div>

        <div class="cell cell-bottom-right-a">
          <slot name="l-vertical"></slot>
        </div>

        <div class="cell cell-bottom-right-b">
          <!-- bottom-right content here (bottom strip) -->
        </div>

      </div>

      <!-- BORDER LAYER (SVG floats on top, purely decorative) -->
      <svg class="bento-borders" viewBox="0 0 780 630" xmlns="http://www.w3.org/2000/svg">

        <!-- OUTER RECTANGLE -->
        <line x1="2"   y1="0"   x2="2"   y2="630" stroke="blue" stroke-width="4"/>
        <line x1="778" y1="0"   x2="778" y2="630" stroke="blue" stroke-width="4"/>
        <line x1="0"   y1="2"   x2="780" y2="2"   stroke="blue" stroke-width="4"/>
        <line x1="0"   y1="628" x2="780" y2="628" stroke="blue" stroke-width="4"/>

        <!-- HORIZONTAL DIVIDER -->
        <line x1="0"   y1="227" x2="780" y2="227" stroke="blue" stroke-width="4"/>

        <!-- VERTICAL DIVIDER top (x=212, narrower top-left) -->
        <line x1="212" y1="0"   x2="212" y2="227" stroke="blue" stroke-width="4"/>

        <!-- VERTICAL DIVIDER bottom (x=280, wider bottom-left) -->
        <line x1="280" y1="227" x2="280" y2="630" stroke="blue" stroke-width="4"/>

        <!-- L-SHAPE inner edges -->
        <line x1="280" y1="403" x2="502" y2="403" stroke="blue" stroke-width="4"/>
        <line x1="500" y1="227" x2="500" y2="405" stroke="blue" stroke-width="4"/>

      </svg>

    </div>
  </div>

</body>
</html>